# 1. Maximum Sum Subarray of Size K

# Brute Force Approach
arr = [2,3,5,2,9,7,1]
k = 3
max_sum = 0

for i in range(len(arr) - k + 1):
    current_sum = 0
    
    for j in range(i,i+k):
        current_sum += arr[j]
        
    if current_sum > max_sum:
        max_sum = current_sum
        
print(max_sum)

# Time Complexity
# Outer loop → O(n)
# Inner loop → O(k)
# Total: O(n * k)

